{
  "manifest_version": 3,
  "name": "Prescan",
  "version": "1.0.0",
  "description": "Scan the current tab URL using a backend API",
  
  "permissions": [
    "activeTab",
    "tabs",
    "notifications"
  ],

  "host_permissions": [
    "http://localhost:8080/*"
  ],

  "icons": {
  "16": "icons/icon16.png",
  "48": "icons/icon48.png",
  "128": "icons/icon128.png"
},

  "action": {
    "default_popup": "popup.html",
    "default_title": "PreScan",
    "default_icon": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png"
  }
  }
}