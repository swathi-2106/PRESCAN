{
  "manifest_version": 3,
  "name": "PreScan",
  "version": "0.1",
  "description": "Scan before you deploy — catch vulnerabilities early.",
  "action": {
    "default_icon": "icon48.png",
    "default_popup": "popup.html"
  },
  "permissions": ["activeTab", "scripting", "downloads"],
  "host_permissions": ["http://*/*", "https://*/*"]
}
